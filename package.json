{
  "name": "@pointnet/cldr-spellout",
  "version": "48.2.0",
  "description": "TypeScript implementation of ICU Rule-Based Number Formatting (RBNF) — converts numbers to words across 89 CLDR locales",
  "author": "pointnet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pointnet/cldr-spellout.git"
  },
  "bugs": {
    "url": "https://github.com/pointnet/cldr-spellout/issues"
  },
  "homepage": "https://pointnet.github.io/cldr-spellout/",
  "keywords": [
    "cldr",
    "rbnf",
    "spellout",
    "number-to-words",
    "i18n",
    "internationalization",
    "locale",
    "icu",
    "number-formatting"
  ],
  "engines": {
    "node": ">=24"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node scripts/post-build.mjs",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs": "npm start --prefix docs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "cldr-rbnf": "48.2.0"
  }
}
